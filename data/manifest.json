{
    "display_information": {
        "name": "ReflectAI",
        "description": "Developer Assistant AI Bot",
        "background_color": "#203266",
        "long_description": "🎯 Your AI-powered developer companion that transforms daily work into career wins! \n\nReflectAI automatically captures, analyzes, and categorizes your engineering achievements, turning them into compelling competency reports for performance reviews, 1:1s, and career discussions. \n\n✨ No more scrambling to remember what you accomplished last quarter - let AI do the heavy lifting while you focus on building amazing things! 🚀"
    },
    "features": {
        "app_home": {
            "home_tab_enabled": true,
            "messages_tab_enabled": true,
            "messages_tab_read_only_enabled": false
        },
        "bot_user": {
            "display_name": "Sage",
            "always_online": true
        }
    },
    "oauth_config": {
        "scopes": {
            "bot": [
                "app_mentions:read",
                "chat:write",
                "im:history",
                "im:read",
                "im:write",
                "channels:history",
                "channels:read",
                "users:read",
                "users.profile:read",
                "mpim:read",
                "mpim:history",
                "files:read",
                "files:write"
            ]
        }
    },
    "settings": {
        "event_subscriptions": {
            "bot_events": [
                "app_mention",
                "message.im",
                "message.channels",
                "message.mpim",
                "app_home_opened"
            ]
        },
        "interactivity": {
            "is_enabled": true
        },
        "org_deploy_enabled": false,
        "socket_mode_enabled": true,
        "token_rotation_enabled": false
    }
}