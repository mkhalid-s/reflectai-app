# ReflectAI Environment Configuration Template
# Copy this file to .env and fill in the values

# =============================================================================
# DOPPLER CONFIGURATION (Preferred for Production)
# =============================================================================

# Doppler Service Token (optional; get from Doppler dashboard)
DOPPLER_TOKEN=replace_with_doppler_service_token

# Doppler Project Configuration
DOPPLER_PROJECT=reflectai
DOPPLER_ENVIRONMENT=dev
DOPPLER_CONFIG=dev
DOPPLER_API_URL=https://api.doppler.com

# Fallback to environment variables if Doppler unavailable
SECRETS_FALLBACK_TO_ENV=true

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# Database (postgres service)
DB_HOST=postgres
DB_PORT=5432
DB_NAME=reflectai
DB_USER=reflectai
DB_PASSWORD=devpassword

# Database Pool Settings
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_ECHO_SQL=false

# Database Connection Timeouts
DB_CONNECT_TIMEOUT=30
DB_QUERY_TIMEOUT=60

# =============================================================================
# REDIS CACHE CONFIGURATION
# =============================================================================

# Redis Connection URL (REQUIRED)
REDIS_URL=redis://localhost:6379/0

# Redis (redis service)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=devpassword

# Redis Server Configuration
REDIS_LOG_LEVEL=notice              # Redis log level: debug, verbose, notice, warning

# LLM Response Cache Configuration
CACHE_MAX_SIZE=1000                 # Maximum LLM cache entries (used by src/core/llm/cache.py)

# =============================================================================
# LLM PROVIDER API KEYS
# =============================================================================

# OpenAI Configuration (Optional - fallback provider)
#OPENAI_API_KEY=replace_with_openai_api_key
#OPENAI_ORG_ID=your_org_id_optional

# Anthropic Configuration (Optional - fallback provider)
# ANTHROPIC_API_KEY=replace_with_anthropic_api_key

# Enterprise LLM Gateway Configuration (Optional)
# Configure this only if your organization provides an OAuth2-authenticated LLM gateway.

LLM_GATEWAY_BASE_URL=https://your-llm-gateway.example.com
LLM_GATEWAY_CLIENT_ID=your_oauth_client_id
LLM_GATEWAY_CLIENT_SECRET=your_oauth_client_secret
LLM_GATEWAY_TOKEN_URL=https://your-llm-gateway.example.com/oauth/token
LLM_GATEWAY_TENANT=default                # Enterprise LLM Gateway tenant identifier
LLM_GATEWAY_STAR=default                  # Enterprise LLM Gateway star/environment identifier
LLM_GATEWAY_OAUTH_SCOPE=api.chat         # OAuth2 scope for API access (default: api.chat)

# AWS Bedrock Configuration (Optional - for Claude via Bedrock)
# AWS_ACCESS_KEY_ID=replace_with_aws_access_key_id
# AWS_SECRET_ACCESS_KEY=your_secret_access_key_here
# AWS_REGION=us-east-1
# AWS_BEDROCK_REGION=us-east-1

# =============================================================================
# SLACK INTEGRATION
# =============================================================================

# Slack Bot Configuration
SLACK_BOT_TOKEN=replace_with_slack_bot_token
SLACK_APP_TOKEN=replace_with_slack_app_token
SLACK_SIGNING_SECRET=your_signing_secret_here
# SLACK_CLIENT_ID=your_client_id_here
# SLACK_CLIENT_SECRET=your_client_secret_here

# Slack Rate Limit Retry Configuration (Optional - defaults to 1 retry)
SLACK_RATE_LIMIT_RETRIES=1

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================

# JWT and Encryption Keys (generate strong random keys)
JWT_SECRET_KEY=your_jwt_secret_key_256_bits_minimum
ENCRYPTION_KEY=your_encryption_key_32_bytes_base64
API_SECRET_KEY=your_api_secret_key_here

# Audit Trail Encryption (Fernet AES-256)
# Generate key with: python scripts/generate_audit_key.py
# CRITICAL: Required for GDPR, CCPA, HIPAA, SOC2 compliance
# Encrypts PII and sensitive data in audit logs
AUDIT_ENCRYPTION_KEY=your_fernet_key_here

# =============================================================================
# TEMPORAL WORKFLOW ENGINE
# =============================================================================

TEMPORAL_HOST=localhost
TEMPORAL_PORT=7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=reflectai-queue
TEMPORAL_TLS_ENABLED=false
TEMPORAL_RUN_LOCAL=true
TEMPORAL_PROMETHEUS_ENABLED=true
TEMPORAL_LOG_LEVEL=INFO

# Temporal Database (postgres service, separate database)
TEMPORAL_DB_HOST=postgres
TEMPORAL_DB_PORT=5432
TEMPORAL_DB_NAME=temporal
TEMPORAL_DB_USER=temporal
TEMPORAL_DB_PASSWORD=temporalpassword

TEMPORAL_WEB_PORT=8088

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================

# Environment
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# Application Settings
APP_NAME=ReflectAI
APP_VERSION=0.1.2-alpha

# Server Ports
# Docker: Uses container ports 3000 (app), 8080 (metrics), 8090 (health)
# Local: Use './rai run app' (runs on port 8000, not configurable here)
APP_PORT=3000                       # Main application port (Docker external mapping)
METRICS_PORT=8080                   # Prometheus metrics endpoint
HEALTH_CHECK_PORT=8090              # Health check endpoint

# Monitoring and Observability
METRICS_ENABLED=true
HEALTH_CHECK_ENABLED=true
CORRELATION_ID_ENABLED=true
JSON_LOGS=false
LOG_ROTATION_MB=100
LOG_RETENTION_DAYS=30

# =============================================================================
# COST MANAGEMENT
# =============================================================================

# Cost Tracking Limits
DAILY_COST_LIMIT_USD=50.00
MONTHLY_COST_LIMIT_USD=1000.00
COST_ALERT_THRESHOLD=0.8

# =============================================================================
# STORAGE CONFIGURATION
# =============================================================================

# Storage backend
STORAGE_TYPE=local                  # Options: local, s3, gcs
STORAGE_PATH=/app/data             # Local storage path

# =============================================================================
# DOCKER CONFIGURATION
# =============================================================================

# Docker image configuration
IMAGE_TAG=latest                    # Docker image tag
BUILD_TARGET=development           # Docker build target: development, production

# =============================================================================
# DEVELOPMENT/TESTING
# =============================================================================

# Test Database (separate from main)
# Built from DB_* variables with _test suffix at runtime
TEST_DB_NAME=reflectai_test

# Feature Flags
ENABLE_MOCK_LLM=false
ENABLE_COST_TRACKING=true
ENABLE_GUARDRAILS=true

# Development Tools
ENABLE_DEBUG_TOOLBAR=true
ENABLE_PROFILING=false
LOAD_TEST_DATA=false