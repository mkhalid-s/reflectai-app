    classDef external fill:#3b82f6,stroke:#1e40af,stroke-width:3px,color:#fff
    classDef app fill:#10b981,stroke:#059669,stroke-width:2px,color:#fff
    classDef business fill:#f59e0b,stroke:#d97706,stroke-width:2px,color:#000
    classDef workflow fill:#8b5cf6,stroke:#7c3aed,stroke-width:2px,color:#fff
    classDef infra fill:#6366f1,stroke:#4f46e5,stroke-width:2px,color:#fff
    classDef data fill:#ec4899,stroke:#db2777,stroke-width:3px,color:#fff
    classDef extsys fill:#14b8a6,stroke:#0d9488,stroke-width:2px,color:#fff

    class Slack,RestAPI,WebPortal external
    class SlackAdapter,APIRoutes,AuthMiddleware,ErrorMiddleware,Port3000,Port8080,Port8090 app
    class LLMGateway,ClassificationEngine,AssessmentEngine,CareerPath,Analytics,Reporting,Notification,AdvisorAgent,AnalysisAgent,ChatResponder,ConvIntelligence,ContextManager business
    class TemporalServer,AssessmentWF,ReportWF,CareerWF,BatchWF,Worker1,Worker2,DBActivities,LLMActivities,ExtActivities,FileActivities workflow
    class ConfigMgr,SecretsMgr,Security,Logging,Metrics,HealthChecks,RedisMgr,MemCache infra
    class UsersTbl,ActivitiesTbl,CompetenciesTbl,CompHistoryTbl,ReportsTbl,SessionsTbl,RedisCache,FileStorage data
    class SlackAPI,EnterpriseGateway,OpenAI,Anthropic,Doppler extsys
