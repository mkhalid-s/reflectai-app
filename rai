    def db_backup(self, args):
        """Backup database to file."""
        from datetime import datetime

        print_header("Creating Database Backup")

        # Create backup directory
        backup_dir = Path("backups/database")
        backup_dir.mkdir(parents=True, exist_ok=True)

        # Generate backup filename
        timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
        backup_file = backup_dir / f"reflectai_{timestamp}.sql"

        print_info(f"Backing up to: {backup_file}")

        # Create backup using pg_dump
        result = run_command([
            "docker", "exec", "reflectai-postgres",
            "pg_dump", "-U", "reflectai_user", "-d", "reflectai"
        ], capture_output=True, check=False)

        if result.returncode == 0:
            backup_file.write_text(result.stdout)
            print_success(f"Backup created: {backup_file}")
            print_info(f"Size: {backup_file.stat().st_size / 1024 / 1024:.2f} MB")
        else:
            print_error("Backup failed")

    def db_restore(self, args):
        """Restore database from backup file."""
        if not args:
            print_error("Usage: ./rai db restore <backup-file>")
            return

        backup_file = Path(args[0])
        if not backup_file.exists():
            print_error(f"Backup file not found: {backup_file}")
            return

        print_header("Restoring Database")
        print_warning("This will overwrite all existing data! Continue? (y/N)")

        if input().lower() != 'y':
            print_info("Restore cancelled")
            return

        print_info(f"Restoring from: {backup_file}")

        # Read backup file
        sql_content = backup_file.read_text()

        # Restore via psql
        result = run_command([
            "docker", "exec", "-i", "reflectai-postgres",
            "psql", "-U", "reflectai_user", "-d", "reflectai"
        ], input=sql_content, capture_output=True, check=False)

        if result.returncode == 0:
            print_success("Database restored successfully")
        else:
            print_error("Restore failed")
            print(result.stderr)

