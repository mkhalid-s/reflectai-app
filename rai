    def _sync_doppler(self, args):
        """Sync configuration from Doppler."""
        print_header("Syncing from Doppler")

        doppler_token = os.environ.get("DOPPLER_TOKEN")
        if not doppler_token:
            print_error("DOPPLER_TOKEN not set")
            print_info("Set it with: export DOPPLER_TOKEN=dp.st.xxx")
            return

        project = os.environ.get("DOPPLER_PROJECT", "reflectai")
        config = os.environ.get("DOPPLER_CONFIG", "dev")

        print_info(f"Project: {project}")
        print_info(f"Config: {config}")

        # Check if doppler CLI is available
        if check_command_exists("doppler"):
            print_info("Using Doppler CLI...")

            output_file = ".env"
            if "--output" in args:
                idx = args.index("--output")
                if idx + 1 < len(args):
                    output_file = args[idx + 1]

            # Use doppler CLI to download secrets
            result = run_command([
                "doppler", "secrets", "download",
                "--project", project,
                "--config", config,
                "--format", "env",
                "--no-file"
            ], capture_output=True, check=False)

            if result.returncode == 0:
                with open(self.project_root / output_file, 'w') as f:
                    f.write(result.stdout)
                print_success(f"Synced to {output_file}")
            else:
                print_error("Failed to sync from Doppler")
                print_error(result.stderr if result.stderr else "Unknown error")
        else:
            print_warning("Doppler CLI not found")
            print_info("Install with: brew install dopplerhq/cli/doppler")
            print_info("Or use the Python SDK integration (requires implementation)")

