    def _get_dir_size(self, path):
        """Calculate directory size in MB."""
        total = 0
        path = Path(path)
        if path.is_file():
            return path.stat().st_size / 1024 / 1024
        for item in path.rglob('*'):
            if item.is_file():
                total += item.stat().st_size
        return total / 1024 / 1024

