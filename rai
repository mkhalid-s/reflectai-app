        show_json = "--json" in args
        show_short = "--short" in args
        show_commit = "--commit" in args
        show_branch = "--branch" in args
        show_full = "--full" in args
        
        try:
            # Import version module
            sys.path.insert(0, str(self.project_root / "src"))
            from version import (
                get_version_string,
                get_short_version,
                get_version_info,
                __git_commit__,
                __git_branch__,
                __git_dirty__,
            )
            
            # Handle different output formats
            if show_json:
                info = get_version_info()
                print(json.dumps(info, indent=2))
                return
            
            if show_short:
                print(get_short_version())
                return
            
            if show_commit:
                print(__git_commit__)
                return
            
            if show_branch:
                print(__git_branch__)
                return
            
            if show_full:
                print(get_version_string())
                return
            
            # Default: Pretty formatted output
            print_header("ReflectAI Version Information")
            
            info = get_version_info()
            
            print(f"{Colors.BOLD}Version Information:{Colors.ENDC}")
            print(f"  Version:       {Colors.GREEN}{info['version']}{Colors.ENDC}")
            print(f"  Full Version:  {Colors.GREEN}{info['version_full']}{Colors.ENDC}")
            print()
            
            print(f"{Colors.BOLD}Git Information:{Colors.ENDC}")
            print(f"  Commit:        {Colors.BLUE}{info['git_commit']}{Colors.ENDC}")
            print(f"  Branch:        {Colors.BLUE}{info['git_branch']}{Colors.ENDC}")
            
            if info['git_dirty']:
                print(f"  Status:        {Colors.YELLOW}Dirty (uncommitted changes){Colors.ENDC}")
            else:
                print(f"  Status:        {Colors.GREEN}Clean{Colors.ENDC}")
            print()
            
            print(f"{Colors.BOLD}Build Information:{Colors.ENDC}")
            print(f"  Build Date:    {info['build_date']}")
            print(f"  Environment:   {info['environment']}")
            print(f"  Python:        {info['python_version']}")
            print(f"  Pkg Manager:   {self.package_manager}")
            print()
            
            # Show warning if working directory is dirty
            if info['git_dirty']:
                print_warning("Working directory has uncommitted changes!")
                print()
            
        except ImportError as e:
            # Fallback if version module can't be imported
            print_header("ReflectAI Version Information")
            print_warning(f"Could not import version module: {e}")
            
            # Try to read version from pyproject.toml as fallback
            pyproject_path = self.project_root / "pyproject.toml"
            if pyproject_path.exists():
                with open(pyproject_path) as f:
                    for line in f:
                        if line.startswith("version"):
                            version = line.split("=")[1].strip().strip('"').strip("'")
                            print_info(f"Version (from pyproject.toml): {version}")
                            break
            else:
                print_info("Version: Unknown")
            
            print_info(f"Python: {sys.version}")
            print_info(f"Package Manager: {self.package_manager}")
    
    def version_bump(self, args):
        """
        Bump version number with semantic versioning.
        
        Usage:
            ./rai version bump major      # 0.1.2-alpha → 1.0.0
            ./rai version bump minor      # 0.1.2-alpha → 0.2.0
            ./rai version bump patch      # 0.1.2-alpha → 0.1.3
            ./rai version bump release    # 0.1.2-alpha → 0.1.2
            ./rai version bump alpha      # 0.1.2-alpha → 0.1.2-alpha.1
            ./rai version bump beta       # 0.1.2-alpha → 0.1.2-beta
            ./rai version bump rc         # 0.1.2-alpha → 0.1.2-rc
        
        Flags:
            --dry-run        Show what would happen without making changes
            --yes            Skip confirmation prompt
            --tag            Create git tag after bump
            --push           Push changes and tags to remote
            --force          Allow bumping with dirty working directory
        """
        if not args:
            print_error("Bump type required: major, minor, patch, release, alpha, beta, rc")
            print_info("Usage: ./rai version bump <type> [--dry-run] [--yes] [--tag] [--push]")
            return
        
        bump_type = args[0]
        dry_run = "--dry-run" in args
        skip_confirm = "--yes" in args
        create_tag = "--tag" in args
        push_remote = "--push" in args
        force = "--force" in args
        
        # Valid bump types
        valid_types = ['major', 'minor', 'patch', 'release', 'alpha', 'beta', 'rc']
        if bump_type not in valid_types:
            print_error(f"Invalid bump type: {bump_type}")
            print_info(f"Valid types: {', '.join(valid_types)}")
            return
        
        print_header(f"Version Bump: {bump_type.upper()}")
        
        # Safety check: ensure working directory is clean
        if not force and not check_git_clean():
            print_error("Working directory has uncommitted changes!")
            print_info("Commit your changes first, or use --force to override")
            return
        
        try:
            # Read current version
            current_version_str = read_version_from_pyproject()
            print_info(f"Current version: {current_version_str}")
            
            # Parse version
            try:
                current_version = SemanticVersion(current_version_str)
            except ValueError as e:
                print_error(f"Failed to parse version: {e}")
                return
            
            # Calculate new version
            if bump_type == 'major':
                new_version = current_version.bump_major()
            elif bump_type == 'minor':
                new_version = current_version.bump_minor()
            elif bump_type == 'patch':
                new_version = current_version.bump_patch()
            elif bump_type == 'release':
                new_version = current_version.release()
            elif bump_type in ['alpha', 'beta', 'rc']:
                new_version = current_version.bump_prerelease(bump_type)
            else:
                print_error(f"Unknown bump type: {bump_type}")
                return
            
            new_version_str = str(new_version)
            print_success(f"New version: {new_version_str}")
            print()
            
            # Show comparison
            print(f"{Colors.BOLD}Version Change:{Colors.ENDC}")
            print(f"  From: {Colors.YELLOW}{current_version_str}{Colors.ENDC}")
            print(f"  To:   {Colors.GREEN}{new_version_str}{Colors.ENDC}")
            print()
            
            if dry_run:
                print_info("Dry run mode - no changes made")
                return
            
            # Confirm action
            if not skip_confirm:
                response = input(f"{Colors.YELLOW}Proceed with version bump? [y/N]: {Colors.ENDC}")
                if response.lower() not in ['y', 'yes']:
                    print_info("Version bump cancelled")
                    return
            
            # Update pyproject.toml
            print_info("Updating pyproject.toml...")
            write_version_to_pyproject(new_version_str)
            print_success("✓ pyproject.toml updated")
            
            # Git commit
            print_info("Creating git commit...")
            commit_message = f"chore: bump version {current_version_str} → {new_version_str}"
            run_command(["git", "add", "pyproject.toml"], check=True)
            run_command(["git", "commit", "-m", commit_message], check=True)
            print_success(f"✓ Git commit created: {commit_message}")
            
            # Create git tag
            if create_tag:
                tag_name = f"v{new_version_str}"
                print_info(f"Creating git tag: {tag_name}...")
                run_command(
                    ["git", "tag", "-a", tag_name, "-m", f"Release {new_version_str}"],
                    check=True
                )
                print_success(f"✓ Git tag created: {tag_name}")
            
            # Push to remote
            if push_remote:
                print_info("Pushing to remote...")
                run_command(["git", "push", "origin", "HEAD"], check=True)
                if create_tag:
                    run_command(["git", "push", "origin", f"v{new_version_str}"], check=True)
                print_success("✓ Changes pushed to remote")
            
            print()
            print_success(f"Version bumped successfully: {current_version_str} → {new_version_str}")
            
            if not create_tag:
                print_info(f"To create a tag: git tag -a v{new_version_str} -m 'Release {new_version_str}'")
            if not push_remote:
                print_info("To push changes: git push origin HEAD && git push origin --tags")
            
        except FileNotFoundError as e:
            print_error(f"Error: {e}")
        except ValueError as e:
            print_error(f"Error: {e}")
        except Exception as e:
            print_error(f"Unexpected error: {e}")
            # Try to rollback
            print_warning("Attempting to rollback changes...")
            try:
                run_command(["git", "reset", "--hard", "HEAD~1"], check=False)
                print_success("Rollback successful")
            except:
                print_error("Rollback failed - please check git status manually")


