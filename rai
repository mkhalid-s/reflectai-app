        """Restore Kubernetes resources from backup."""
        if not args:
            backup_dir = self.project_root / "k8s" / "backups"
            if backup_dir.exists():
                print_info("Available backups:")
                for backup in sorted(backup_dir.glob("backup_*.yaml")):
                    print_info(f"  {backup.name}")
            print_error("Usage: ./rai k8s restore <backup-file>")
            return

        backup_file = args[0]
        print_header(f"Restoring from: {backup_file}")

        print_warning("This will overwrite existing resources!")
        if input("Continue? (y/N): ").lower() == 'y':
            run_command(["kubectl", "apply", "-f", backup_file])

    def _setup_kind_cluster(self):
        """Setup kind cluster for local development."""
        cluster_name = "reflectai-dev"

        # Check if cluster exists
        result = run_command(["kind", "get", "clusters"], capture_output=True, check=False)
        if cluster_name in result.stdout:
            print_info(f"Kind cluster '{cluster_name}' already exists")
            return

        # Create cluster config if it doesn't exist
        kind_config = self.project_root / "k8s" / "kind-cluster.yaml"
        if not kind_config.exists():
            self._create_kind_config(kind_config)

        print_info(f"Creating kind cluster: {cluster_name}")
        run_command(["kind", "create", "cluster", "--name", cluster_name, "--config", str(kind_config)])

        # Wait for cluster to be ready
        run_command(["kubectl", "cluster-info", "--context", f"kind-{cluster_name}"])

    def _create_kind_config(self, config_path):
        """Create kind cluster configuration."""
        config_content = """kind: Cluster
apiVersion: kind.x-k8s.io/v1alpha4
name: reflectai-dev
nodes:
- role: control-plane
  kubeadmConfigPatches:
  - |
    kind: InitConfiguration
    nodeRegistration:
      kubeletExtraArgs:
        node-labels: "ingress-ready=true"
  extraPortMappings:
  - containerPort: 80
    hostPort: 8080
    protocol: TCP
  - containerPort: 443
    hostPort: 8443
    protocol: TCP
"""
        with open(config_path, 'w') as f:
            f.write(config_content)
        print_info(f"Created kind cluster config: {config_path}")

    def _deploy_local_k8s(self):
        """Deploy to local Kubernetes."""
        namespace = "reflectai"

        # Create namespace
        print_info("Creating namespace...")
        run_command(["kubectl", "create", "namespace", namespace], check=False)

        # Apply base configurations
        k8s_dir = self.project_root / "k8s"
        configs = ["namespace.yaml", "configmap.yaml", "deployment.yaml", "service.yaml"]

        for config in configs:
            config_path = k8s_dir / config
            if config_path.exists():
                print_info(f"Applying {config}...")
                run_command(["kubectl", "apply", "-f", str(config_path)])
            else:
                print_warning(f"Config file not found: {config}")

        # Wait for deployment
        print_info("Waiting for deployment to be ready...")
        run_command([
            "kubectl", "rollout", "status", "deployment/reflectai-app",
            "-n", namespace, "--timeout=300s"
        ], check=False)

        print_success("Deployed to local Kubernetes!")
        print_info("Use './rai k8s port-forward' to access the application")
        print_info("Use './rai k8s status' to check deployment status")

