    def k8s_backup(self, args):
        """Backup Kubernetes resources."""
        namespace = "reflectai"
        backup_dir = self.project_root / "k8s" / "backups"
        backup_dir.mkdir(parents=True, exist_ok=True)

        timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
        backup_file = backup_dir / f"backup_{timestamp}.yaml"

        print_header(f"Backing up Kubernetes resources to: {backup_file}")

        resources = ["deployments", "services", "configmaps", "secrets", "ingress"]

        with open(backup_file, 'w') as f:
            for resource in resources:
                print_info(f"Backing up {resource}...")
                result = run_command([
                    "kubectl", "get", resource, "-n", namespace, "-o", "yaml"
                ], capture_output=True, check=False)

                if result.returncode == 0:
                    f.write(f"# {resource}\n")
                    f.write(result.stdout)
                    f.write("\n---\n")

        print_success(f"Backup complete: {backup_file}")

