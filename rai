        run_command([
            "docker", "exec", "reflectai-redis",
            "redis-cli", "-a", redis_password, "BGSAVE"
        ])

        print_info("Waiting for save to complete...")
        time.sleep(2)

        # Copy dump.rdb from container
        backup_dir = self.project_root / "backups" / "redis"
        backup_dir.mkdir(parents=True, exist_ok=True)

        timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
        backup_file = backup_dir / f"redis_backup_{timestamp}.rdb"

        print_info(f"Copying backup to {backup_file}...")
        run_command([
            "docker", "cp",
            "reflectai-redis:/data/dump.rdb",
            str(backup_file)
        ])

        print_success(f"Backup complete: {backup_file}")

