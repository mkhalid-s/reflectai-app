    def secrets_get(self, args):
        """Get a specific secret value."""
        if not args:
            print_error("Usage: ./rai secrets get <secret-name>")
            return

        secret_name = args[0]
        value = os.environ.get(secret_name)

        if value:
            print_success(f"{secret_name}:")
            # Mask the value for security
            if len(value) > 8:
                masked = value[:4] + "*" * (len(value) - 8) + value[-4:]
            else:
                masked = "*" * len(value)
            print(f"  {masked}")
            print_info("(masked for security)")
        else:
            print_error(f"Secret '{secret_name}' not found")

    def secrets_set(self, args):
        """Set a secret value."""
        if len(args) < 2:
            print_error("Usage: ./rai secrets set <name> <value>")
            return

        secret_name = args[0]
        secret_value = args[1]

        env_file = self.project_root / ".env"

        # Read existing .env
        lines = []
        found = False
        if env_file.exists():
            with open(env_file, 'r') as f:
                lines = f.readlines()

            # Update existing or add new
            for i, line in enumerate(lines):
                if line.startswith(f"{secret_name}="):
                    lines[i] = f"{secret_name}={secret_value}\n"
                    found = True
                    break

        if not found:
            lines.append(f"{secret_name}={secret_value}\n")

        # Write back
        with open(env_file, 'w') as f:
            f.writelines(lines)

        print_success(f"Secret '{secret_name}' set successfully")

