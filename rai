    def backup_verify(self, args):
        """Verify backup integrity."""
        if not args:
            print_error("Usage: ./rai backup verify <backup-path>")
            return

        backup_path = Path(args[0])
        if not backup_path.exists():
            print_error(f"Backup not found: {backup_path}")
            return

        print_header(f"Verifying Backup: {backup_path.name}")

        issues = []

        # Check metadata
        metadata_file = backup_path / "metadata.json"
        if metadata_file.exists():
            print_success("✓ Metadata file found")
            try:
                import json
                json.loads(metadata_file.read_text())
                print_success("✓ Metadata is valid JSON")
            except json.JSONDecodeError:
                issues.append("Metadata file is corrupted")
                print_error("✗ Metadata file is corrupted")
        else:
            print_warning("⚠ No metadata file")

        # Check database backup
        db_file = backup_path / "database.sql"
        if db_file.exists():
            if db_file.stat().st_size > 0:
                print_success(f"✓ Database backup found ({db_file.stat().st_size / 1024 / 1024:.2f} MB)")
            else:
                issues.append("Database backup is empty")
                print_error("✗ Database backup is empty")

        # Check Redis backup
        redis_file = backup_path / "redis.rdb"
        if redis_file.exists():
            if redis_file.stat().st_size > 0:
                print_success(f"✓ Redis backup found ({redis_file.stat().st_size / 1024:.2f} KB)")
            else:
                issues.append("Redis backup is empty")
                print_error("✗ Redis backup is empty")

        if not issues:
            print_success("\n✓ Backup verification passed")
        else:
            print_error(f"\n✗ Backup verification failed ({len(issues)} issues)")
            for issue in issues:
                print_error(f"  • {issue}")

