    def backup_full(self, args):
        """Create full system backup (database, redis, configs)."""
        from datetime import datetime

        print_header("Creating Full System Backup")

        # Create backup directory
        backup_dir = Path("backups/full")
        backup_dir.mkdir(parents=True, exist_ok=True)

        timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
        backup_name = f"full_backup_{timestamp}"
        backup_path = backup_dir / backup_name
        backup_path.mkdir(exist_ok=True)

        print_info(f"Backup location: {backup_path}\n")

        # Backup database
        print_info("1/4 Backing up database...")
        self.backup_database([str(backup_path / "database.sql")])

        # Backup Redis
        print_info("2/4 Backing up Redis...")
        self.backup_redis([str(backup_path / "redis.rdb")])

        # Backup configs
        print_info("3/4 Backing up configurations...")
        self.backup_configs([str(backup_path / "configs")])

        # Create metadata
        print_info("4/4 Creating backup metadata...")
        metadata = {
            "timestamp": timestamp,
            "version": self._get_version(),
            "services": ["database", "redis", "configs"],
        }
        import json
        (backup_path / "metadata.json").write_text(json.dumps(metadata, indent=2))

        print_success(f"\n✓ Full backup completed: {backup_path}")
        print_info(f"Size: {self._get_dir_size(backup_path):.2f} MB")

    def backup_incremental(self, args):
        """Create incremental backup (only changes since last backup)."""
        from datetime import datetime

        print_header("Creating Incremental Backup")

        backup_dir = Path("backups/incremental")
