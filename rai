    def clean_cache(self, args):
        """Clean cache files."""
        print_header("Cleaning Cache Files")

        cache_dirs = [
            ".pytest_cache",
            ".mypy_cache",
            ".ruff_cache",
            "htmlcov",
            "dist",
            "build",
            ".coverage"
        ]

        for cache_dir in cache_dirs:
            path = self.project_root / cache_dir
            if path.exists():
                print_info(f"Removing {cache_dir}/")
                if path.is_dir():
                    shutil.rmtree(path)
                else:
                    path.unlink()

        # Clean __pycache__ directories
        for pycache in self.project_root.rglob("__pycache__"):
            print_info(f"Removing {pycache.relative_to(self.project_root)}")
            shutil.rmtree(pycache)

        # Clean .pyc files
        for pyc in self.project_root.rglob("*.pyc"):
            print_info(f"Removing {pyc.relative_to(self.project_root)}")
            pyc.unlink()

        print_success("Cache cleaned!")

    def clean_docker(self, args):
        """Clean Docker containers and images."""
        print_header("Cleaning Docker")

        if not check_command_exists("docker"):
            print_warning("Docker not found")
            return

        # Stop and remove containers
        containers = ["reflectai-postgres", "reflectai-redis", "reflectai-app"]
        for container in containers:
            print_info(f"Stopping {container}...")
            run_command(["docker", "stop", container], check=False)
            run_command(["docker", "rm", container], check=False)

        print_success("Docker cleaned!")

