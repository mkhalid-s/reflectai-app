        backup_path.mkdir(exist_ok=True)

        print_info(f"Backup location: {backup_path}")
        print_warning("Incremental backup requires comparison with last full backup")

        # For now, create a full backup
        print_info("Creating snapshot...")
        self.backup_full([])

    def backup_database(self, args):
        """Backup database only."""
        output_file = args[0] if args else None

        if not output_file:
            from datetime import datetime
            backup_dir = Path("backups/database")
            backup_dir.mkdir(parents=True, exist_ok=True)
            timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
            output_file = str(backup_dir / f"database_{timestamp}.sql")

        print_info(f"Backing up database to: {output_file}")

        result = run_command([
            "docker", "exec", "reflectai-postgres",
            "pg_dump", "-U", "reflectai_user", "-d", "reflectai"
        ], capture_output=True, check=False)

        if result.returncode == 0:
            Path(output_file).write_text(result.stdout)
            print_success(f"Database backup created: {output_file}")
        else:
            print_error("Database backup failed")

    def backup_redis(self, args):
        """Backup Redis data."""
        output_file = args[0] if args else None

        if not output_file:
            from datetime import datetime
            backup_dir = Path("backups/redis")
            backup_dir.mkdir(parents=True, exist_ok=True)
            timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
            output_file = str(backup_dir / f"redis_{timestamp}.rdb")

        print_info(f"Backing up Redis to: {output_file}")

        # Trigger Redis save
        run_command([
            "docker", "exec", "reflectai-redis",
            "redis-cli", "SAVE"
        ], check=False)

        # Copy RDB file
        result = run_command([
            "docker", "cp", "reflectai-redis:/data/dump.rdb", output_file
        ], capture_output=True, check=False)

        if result.returncode == 0:
            print_success(f"Redis backup created: {output_file}")
        else:
            print_error("Redis backup failed")

