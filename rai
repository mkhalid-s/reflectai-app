# ANSI color codes
class Colors:
    HEADER = '\033[95m'
    BLUE = '\033[94m'
    GREEN = '\033[92m'
    YELLOW = '\033[93m'
    RED = '\033[91m'
    ENDC = '\033[0m'
    BOLD = '\033[1m'

def print_header(message: str):
    """Print a colored header message."""
    print(f"\n{Colors.HEADER}{Colors.BOLD}{'=' * 60}{Colors.ENDC}")
    print(f"{Colors.HEADER}{Colors.BOLD}{message}{Colors.ENDC}")
    print(f"{Colors.HEADER}{Colors.BOLD}{'=' * 60}{Colors.ENDC}\n")

def print_success(message: str):
    """Print a success message."""
    print(f"{Colors.GREEN}✅ {message}{Colors.ENDC}")

def print_error(message: str):
    """Print an error message."""
    print(f"{Colors.RED}❌ {message}{Colors.ENDC}")

def print_warning(message: str):
    """Print a warning message."""
    print(f"{Colors.YELLOW}⚠️  {message}{Colors.ENDC}")

def print_info(message: str):
    """Print an info message."""
    print(f"{Colors.BLUE}ℹ️  {message}{Colors.ENDC}")

def run_command(cmd: List[str], check: bool = True, capture_output: bool = False, cwd: Optional[Path] = None) -> subprocess.CompletedProcess:
    """Run a command and return the result."""
    cwd = cwd or PROJECT_ROOT
    print_info(f"Running: {' '.join(cmd)}")

    try:
        if capture_output:
            return subprocess.run(cmd, cwd=cwd, check=check, capture_output=True, text=True)
        else:
            return subprocess.run(cmd, cwd=cwd, check=check)
    except subprocess.CalledProcessError as e:
        if check:
            print_error(f"Command failed: {e}")
            sys.exit(1)
        return e

def check_command_exists(command: str) -> bool:
    """Check if a command exists in the system."""
    return shutil.which(command) is not None

def detect_package_manager() -> str:
    """Detect which Python package manager to use."""
    if check_command_exists("pdm"):
        return "pdm"
    else:
        return "pdm"  # Will be installed during setup

def detect_environment() -> Dict[str, bool]:
    """Detect the current development environment."""
    return {
        "docker": os.path.exists("/.dockerenv"),
        "devcontainer": os.environ.get("REMOTE_CONTAINERS") == "true",
        "vscode": os.environ.get("TERM_PROGRAM") == "vscode",
        "ci": os.environ.get("CI") == "true",
        "local": True
    }

# ==================== VERSION MANAGEMENT UTILITIES ====================

class SemanticVersion:
    """Semantic version parser and manipulator."""
    
    # Regex pattern for semantic versioning: MAJOR.MINOR.PATCH[-PRERELEASE][+BUILD]
    VERSION_PATTERN = re.compile(
        r'^(?P<major>\d+)\.(?P<minor>\d+)\.(?P<patch>\d+)'
        r'(?:-(?P<prerelease>[a-zA-Z0-9.-]+))?'
        r'(?:\+(?P<build>[a-zA-Z0-9.-]+))?$'
    )
    
    def __init__(self, version_string: str):
        """Parse a semantic version string."""
        self.original = version_string
        match = self.VERSION_PATTERN.match(version_string)
        
        if not match:
            raise ValueError(f"Invalid semantic version: {version_string}")
        
        self.major = int(match.group('major'))
        self.minor = int(match.group('minor'))
        self.patch = int(match.group('patch'))
        self.prerelease = match.group('prerelease')
        self.build = match.group('build')
    
    def bump_major(self) -> 'SemanticVersion':
        """Bump major version (resets minor, patch, and prerelease)."""
        return SemanticVersion(f"{self.major + 1}.0.0")
    
    def bump_minor(self) -> 'SemanticVersion':
        """Bump minor version (resets patch and prerelease)."""
        return SemanticVersion(f"{self.major}.{self.minor + 1}.0")
    
    def bump_patch(self) -> 'SemanticVersion':
        """Bump patch version (removes prerelease)."""
        return SemanticVersion(f"{self.major}.{self.minor}.{self.patch + 1}")
    
    def bump_prerelease(self, prerelease_type: Optional[str] = None) -> 'SemanticVersion':
        """
        Bump or change prerelease version.
        
        Args:
            prerelease_type: Type of prerelease (alpha, beta, rc, etc.)
        """
        if prerelease_type:
            # Change prerelease type
            return SemanticVersion(f"{self.major}.{self.minor}.{self.patch}-{prerelease_type}")
        
        if not self.prerelease:
            # No prerelease, add alpha
            return SemanticVersion(f"{self.major}.{self.minor}.{self.patch}-alpha")
        
        # Try to increment numeric suffix
        parts = self.prerelease.split('.')
        if len(parts) > 1 and parts[-1].isdigit():
            # Has numeric suffix, increment it
            parts[-1] = str(int(parts[-1]) + 1)
            new_prerelease = '.'.join(parts)
        else:
            # No numeric suffix, add .1
            new_prerelease = f"{self.prerelease}.1"
        
        return SemanticVersion(f"{self.major}.{self.minor}.{self.patch}-{new_prerelease}")
    
    def release(self) -> 'SemanticVersion':
        """Remove prerelease suffix to create a stable release."""
        return SemanticVersion(f"{self.major}.{self.minor}.{self.patch}")
    
    def __str__(self) -> str:
        """Get version string without build metadata."""
        version = f"{self.major}.{self.minor}.{self.patch}"
        if self.prerelease:
            version += f"-{self.prerelease}"
        return version
    
    def __repr__(self) -> str:
        return f"SemanticVersion('{str(self)}')"

def read_version_from_pyproject() -> str:
    """Read current version from pyproject.toml."""
    pyproject_path = PROJECT_ROOT / "pyproject.toml"
    if not pyproject_path.exists():
        raise FileNotFoundError("pyproject.toml not found")
    
    with open(pyproject_path, 'r') as f:
        for line in f:
            if line.strip().startswith('version'):
                # Extract version from: version = "0.1.2-alpha"
                version = line.split('=')[1].strip().strip('"').strip("'")
                return version
    
    raise ValueError("Version not found in pyproject.toml")

def write_version_to_pyproject(new_version: str) -> None:
    """Update version in pyproject.toml."""
    pyproject_path = PROJECT_ROOT / "pyproject.toml"
    
    # Read all lines
    with open(pyproject_path, 'r') as f:
        lines = f.readlines()
    
    # Update version line
    with open(pyproject_path, 'w') as f:
        for line in lines:
            if line.strip().startswith('version'):
                # Preserve indentation and quote style
                indent = len(line) - len(line.lstrip())
                quote_char = '"' if '"' in line else "'"
                f.write(f"{' ' * indent}version = {quote_char}{new_version}{quote_char}\n")
            else:
                f.write(line)

def check_git_clean() -> bool:
    """Check if git working directory is clean."""
    try:
        result = subprocess.run(
            ["git", "status", "--porcelain"],
            capture_output=True,
            text=True,
            check=True,
            cwd=PROJECT_ROOT
        )
        return not bool(result.stdout.strip())
    except:
        return False

class DevCLI:
    """Main development CLI class."""

    def __init__(self):
        self.project_root = PROJECT_ROOT
        self.package_manager = detect_package_manager()
        self.environment = detect_environment()

    # ==================== SETUP COMMANDS ====================

    def setup_all(self, args):
        """Complete development environment setup."""
        print_header("Complete Development Setup")

        self.setup_pdm(args)
        self.setup_deps(args)
        self.setup_db(args)
        self.setup_redis(args)
        self.setup_temporal(args)
        self.setup_secrets(args)

        print_success("Development environment setup complete!")

    def setup_pdm(self, args):
        """Install and setup PDM package manager."""
        print_header("Setting Up PDM")

        if check_command_exists("pdm"):
            print_info("PDM already installed")
        else:
            print_info("Installing PDM...")
            # Try different installation methods
            install_success = False

            # First try pipx (recommended for externally managed environments)
            if check_command_exists("pipx"):
                try:
                    run_command(["pipx", "install", "pdm"])
                    install_success = True
                    print_info("PDM installed via pipx")
                except:
                    pass

            # If pipx failed or doesn't exist, try pip with --user flag
            if not install_success:
                try:
                    run_command(["python3", "-m", "pip", "install", "--user", "pdm"])
                    install_success = True
                    print_info("PDM installed via pip --user")
                except:
                    pass

            # If both methods failed, try with --break-system-packages (last resort)
            if not install_success:
                try:
                    run_command(["python3", "-m", "pip", "install", "--break-system-packages", "pdm"])
                    install_success = True
                    print_warning("PDM installed with --break-system-packages flag")
                except:
                    pass

            if not install_success:
                print_error("Failed to install PDM. Please install it manually:")
                print_info("  Option 1 (recommended): brew install pipx && pipx install pdm")
                print_info("  Option 2: python3 -m pip install --user pdm")
                sys.exit(1)

        # Initialize PDM project if pyproject.toml doesn't exist
        pyproject_path = self.project_root / "pyproject.toml"
        if not pyproject_path.exists():
            print_info("Initializing PDM project...")
            run_command(["pdm", "init", "--non-interactive"], check=False)

        # Handle virtual environment setup intelligently
        venv_path = self.project_root / ".venv"
        if venv_path.exists():
            print_info("Found existing .venv, checking compatibility...")
            # Check if the existing venv has a compatible Python version
            venv_python = venv_path / "bin" / "python"
            if venv_python.exists():
                result = run_command([str(venv_python), "--version"], capture_output=True, check=False)
                if result.returncode == 0:
                    version_info = result.stdout.strip()
                    print_info(f"Existing venv has {version_info}")
                    # Tell PDM to use the existing virtual environment
                    run_command(["pdm", "use", "-f", str(venv_python)], check=False)
                    print_info("Using existing virtual environment")
                else:
                    print_warning("Existing .venv appears corrupted, will create new one")
                    # Remove corrupted venv and create new
                    shutil.rmtree(venv_path)
                    self._create_new_venv()
            else:
                print_warning("Existing .venv appears incomplete, will create new one")
                shutil.rmtree(venv_path)
                self._create_new_venv()
        else:
            print_info("No existing .venv found, creating new virtual environment...")
            self._create_new_venv()

        print_success("PDM setup complete!")

    def _create_new_venv(self):
        """Create a new virtual environment with compatible Python version."""
        # Try to find a compatible Python version
        compatible_pythons = ["python3.12", "python3.11", "python3"]

        for python_cmd in compatible_pythons:
            if check_command_exists(python_cmd):
                print_info(f"Trying to create venv with {python_cmd}...")
                try:
                    run_command(["pdm", "use", "-f", python_cmd])
                    return
                except:
                    continue

        print_error("Could not create virtual environment with compatible Python version")
        print_info("Please ensure Python 3.11 or 3.12 is installed, or update pyproject.toml to support Python 3.13")

    def setup_deps(self, args):
        """Install project dependencies."""
        print_header("Installing Dependencies")

        run_command(["pdm", "install"])

        # Install pre-commit hooks
        if check_command_exists("pre-commit"):
            print_info("Setting up pre-commit hooks...")
            run_command(["pre-commit", "install"], check=False)

        print_success("Dependencies installed!")

    def setup_db(self, args):
        """Setup database."""
        print_header("Setting Up Database")

        # Check if PostgreSQL is running
        if check_command_exists("docker"):
            # Start PostgreSQL in Docker
            print_info("Starting PostgreSQL in Docker...")
            run_command([
                "docker", "run", "-d",
                "--name", "reflectai-postgres",
                "-e", "POSTGRES_USER=reflectai",
                "-e", "POSTGRES_PASSWORD=reflectai",
                "-e", "POSTGRES_DB=reflectai",
                "-p", "5432:5432",
                "postgres:15-alpine"
            ], check=False)

            # Wait for PostgreSQL to be ready
            print_info("Waiting for PostgreSQL to be ready...")
            time.sleep(5)

        # Run migrations if Alembic is available
        if check_command_exists("alembic"):
            print_info("Running database migrations...")
            run_command(["alembic", "upgrade", "head"], check=False)

        print_success("Database setup complete!")

    def setup_redis(self, args):
        """Setup Redis."""
        print_header("Setting Up Redis")

        if check_command_exists("docker"):
            # Start Redis in Docker
            print_info("Starting Redis in Docker...")
            run_command([
                "docker", "run", "-d",
                "--name", "reflectai-redis",
                "-p", "6379:6379",
                "redis:7-alpine"
            ], check=False)

            print_success("Redis setup complete!")
        else:
            print_warning("Docker not found. Please install Redis manually.")

    def setup_temporal(self, args):
        """Setup Temporal workflow server using docker-compose services."""
        print_header("Setting Up Temporal")

        if check_command_exists("docker"):
            compose_cmd = "docker-compose" if check_command_exists("docker-compose") else "docker compose"

            print_info("Starting Temporal services using docker-compose...")

            # Start Temporal-related services from docker-compose.yml
            run_command([
                *compose_cmd.split(),
                "-f", "docker-compose.yml",
                "up", "-d",
                "temporal-postgres",
                "temporal",
                "temporal-web"
            ], check=False)

            # Wait for services to be ready
            print_info("Waiting for Temporal services to be ready...")
            time.sleep(15)

            print_success("Temporal setup complete!")
            print_info("Temporal Server: localhost:7233")
            print_info("Temporal Web UI: http://localhost:8088")
        else:
            print_warning("Docker not found. Please install Docker to run Temporal.")

    def setup_secrets(self, args):
        """Setup secrets and environment variables."""
        print_header("Setting Up Secrets")

        env_file = self.project_root / ".env"
        env_example = self.project_root / ".env.example"

        if not env_file.exists() and env_example.exists():
            print_info("Creating .env file from .env.example...")
            shutil.copy(env_example, env_file)
            print_warning("Please update .env file with your actual values!")
        elif env_file.exists():
            print_info(".env file already exists")
        else:
            print_warning("No .env.example found. Creating basic .env file...")
            with open(env_file, 'w') as f:
                f.write("# ReflectAI Environment Variables\n")
                f.write("ENVIRONMENT=development\n")
                f.write("DEBUG=true\n")
                f.write("DATABASE_URL=postgresql://reflectai:reflectai@localhost:5432/reflectai\n")
                f.write("REDIS_URL=redis://localhost:6379\n")

        print_success("Secrets setup complete!")

    # ==================== RUN COMMANDS ====================

    def run_app(self, args):
        """Run the application."""
        print_header("Running Application")

        # Check if PDM is available
        if not check_command_exists("pdm"):
            print_error("PDM not found! Run './rai setup pdm' first")
            return

        # Run the FastAPI application with uvicorn
        app_file = self.project_root / "src" / "app.py"

        if app_file.exists():
            print_info("Starting ReflectAI FastAPI application...")
            run_command(["pdm", "run", "uvicorn", "src.app:app", "--reload", "--host", "0.0.0.0", "--port", "8000"])
        else:
            print_error("No app.py found in src/")
            print_info("Expected file: src/app.py")

    def run_worker(self, args):
        """Run background workers."""
        print_header("Running Background Workers")
        print_warning("Worker functionality not yet implemented")

    def run_docker(self, args):
        """Run in Docker (deprecated - use 'docker up' instead)."""
        print_warning("'run docker' is deprecated. Use './rai docker up' instead")
        self.docker_up(args)

    # ==================== DOCKER COMMANDS ====================

    def docker_build(self, args):
        """Build Docker images."""
        target = args[0] if args else "development"

        print_header(f"Building Docker Image ({target})")

        cmd = [
            "docker", "build",
            "-t", f"reflectai:{target}",
            "--target", target,
            "."
        ]

        if args and "--no-cache" in args:
            cmd.append("--no-cache")

        run_command(cmd)
        print_success(f"Docker image built: reflectai:{target}")

    def docker_up(self, args):
        """Start Docker containers."""
        env = args[0] if args else "dev"

        print_header(f"Starting Docker Containers ({env})")

        # Check docker-compose exists
        compose_cmd = "docker-compose" if check_command_exists("docker-compose") else "docker compose"

        # Build command based on environment
        if env == "dev" or env == "development":
            cmd = [*compose_cmd.split(), "-f", "docker-compose.yml", "-f", "docker/docker-compose.dev.yml", "up", "-d"]
        elif env == "prod" or env == "production":
            cmd = [*compose_cmd.split(), "-f", "docker-compose.yml", "-f", "docker/docker-compose.prod.yml", "up", "-d"]
        elif env == "test" or env == "testing":
            cmd = [*compose_cmd.split(), "-f", "docker-compose.yml", "-f", "docker/docker-compose.test.yml", "up", "--abort-on-container-exit"]
        elif env == "monitoring":
            cmd = [*compose_cmd.split(), "-f", "docker-compose.yml", "-f", "docker/docker-compose.monitoring.yml", "up", "-d"]
        else:
            cmd = [*compose_cmd.split(), "up", "-d"]

        # Add build flag if requested
        if "--build" in args:
            cmd.insert(-1, "--build")

        run_command(cmd)

        print_success("Docker containers started!")
        print_info(f"Application: http://localhost:3000")
        print_info(f"Health check: http://localhost:8090/health")

        if env in ["dev", "development"]:
            print_info(f"Redis Commander: http://localhost:8081 (admin/admin)")
            print_info(f"PgAdmin: http://localhost:5050 (admin@reflectai.com/admin)")

    def docker_down(self, args):
        """Stop Docker containers."""
        print_header("Stopping Docker Containers")

        compose_cmd = "docker-compose" if check_command_exists("docker-compose") else "docker compose"

        # Determine which compose files to use (must match docker_up)
        env = args[0] if args else "dev"
        
        # Build command with same compose files as docker_up
        if env == "dev" or env == "development":
            cmd = [*compose_cmd.split(), "-f", "docker-compose.yml", "-f", "docker/docker-compose.dev.yml", "down"]
        elif env == "prod" or env == "production":
            cmd = [*compose_cmd.split(), "-f", "docker-compose.yml", "-f", "docker/docker-compose.prod.yml", "down"]
        elif env == "test" or env == "testing":
            cmd = [*compose_cmd.split(), "-f", "docker-compose.yml", "-f", "docker/docker-compose.test.yml", "down"]
        elif env == "monitoring":
            cmd = [*compose_cmd.split(), "-f", "docker-compose.yml", "-f", "docker/docker-compose.monitoring.yml", "down"]
        else:
            cmd = [*compose_cmd.split(), "down"]

        # Check if we should remove volumes
        if "--volumes" in args:
            print_warning("This will delete all data volumes!")
            if input("Continue? (y/N): ").lower() == 'y':
                cmd.append("-v")
                run_command(cmd)
            else:
                return
        else:
            run_command(cmd)

        print_success("Docker containers stopped")

    def docker_restart(self, args):
        """Restart Docker containers."""
        service = args[0] if args else None

        print_header(f"Restarting {'Service: ' + service if service else 'All Containers'}")

        compose_cmd = "docker-compose" if check_command_exists("docker-compose") else "docker compose"

        if service:
            run_command([*compose_cmd.split(), "restart", service])
        else:
            run_command([*compose_cmd.split(), "restart"])

        print_success("Restart complete")

    def docker_logs(self, args):
        """View Docker container logs."""
        service = args[0] if args else "app"
        follow = "--follow" in args or "-f" in args

        print_header(f"Docker Logs: {service}")

        compose_cmd = "docker-compose" if check_command_exists("docker-compose") else "docker compose"

        cmd = [*compose_cmd.split(), "logs"]
        if follow:
            cmd.append("-f")
        else:
            cmd.extend(["--tail", "50"])
        cmd.append(service)

        try:
            run_command(cmd)
        except KeyboardInterrupt:
            print_info("\nStopped following logs")

    def docker_exec(self, args):
        """Execute command in Docker container."""
        service = args[0] if args else "app"
        command = args[1:] if len(args) > 1 else ["bash"]

        print_header(f"Executing in {service}")

        compose_cmd = "docker-compose" if check_command_exists("docker-compose") else "docker compose"

        cmd = [*compose_cmd.split(), "exec", service] + command
        run_command(cmd)

    def docker_status(self, args):
        """Show Docker container status."""
        print_header("Docker Container Status")

        compose_cmd = "docker-compose" if check_command_exists("docker-compose") else "docker compose"

        run_command([*compose_cmd.split(), "ps"])

        print_info("\nContainer Statistics:")
        run_command(["docker", "stats", "--no-stream"])

    def docker_clean(self, args):
        """Clean up Docker resources."""
        print_header("Cleaning Docker Resources")

        print_warning("This will remove:")
        print_warning("- Stopped containers")
        print_warning("- Unused networks")
        print_warning("- Dangling images")
        print_warning("- Build cache")

        if input("\nContinue? (y/N): ").lower() == 'y':
            print_info("Removing stopped containers...")
            run_command(["docker", "container", "prune", "-f"])

            print_info("Removing unused networks...")
            run_command(["docker", "network", "prune", "-f"])

            print_info("Removing dangling images...")
            run_command(["docker", "image", "prune", "-f"])

            if "--all" in args:
                print_info("Removing all unused images...")
                run_command(["docker", "image", "prune", "-a", "-f"])

            print_info("Clearing build cache...")
            run_command(["docker", "builder", "prune", "-f"])

            print_success("Docker cleanup complete!")

    def docker_test(self, args):
        """Run tests in Docker container."""
        print_header("Running Tests in Docker")

        compose_cmd = "docker-compose" if check_command_exists("docker-compose") else "docker compose"

        cmd = [
            *compose_cmd.split(),
            "-f", "docker-compose.yml",
            "-f", "docker/docker-compose.test.yml",
            "up", "--build", "--abort-on-container-exit"
        ]

        run_command(cmd)
        print_success("Tests completed!")

    def docker_push(self, args):
        """Push Docker image to registry."""
        if not args:
            print_error("Usage: ./rai docker push <image:tag> [registry]")
            print_info("Example: ./dev docker push reflectai:latest docker.io/myuser")
            return

        image = args[0]
        registry = args[1] if len(args) > 1 else None

        print_header(f"Pushing Docker Image: {image}")

        # Tag for registry if provided
        if registry:
            registry_image = f"{registry}/{image}"
            print_info(f"Tagging image for registry: {registry_image}")
            run_command(["docker", "tag", image, registry_image])
            image = registry_image

        # Push to registry
        print_info(f"Pushing {image}...")
        run_command(["docker", "push", image])
        print_success(f"Image pushed: {image}")

    def docker_pull(self, args):
        """Pull Docker image from registry."""
        if not args:
            print_error("Usage: ./rai docker pull <image:tag>")
            return

        image = args[0]
        print_header(f"Pulling Docker Image: {image}")
        run_command(["docker", "pull", image])
        print_success(f"Image pulled: {image}")

    def docker_tag(self, args):
        """Tag Docker image."""
        if len(args) < 2:
            print_error("Usage: ./rai docker tag <source> <target>")
            print_info("Example: ./dev docker tag reflectai:dev reflectai:latest")
            return

        source = args[0]
