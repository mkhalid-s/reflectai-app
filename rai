    def restore_full(self, args):
        """Restore full system from backup."""
        if not args:
            print_error("Usage: ./rai restore full <backup-path>")
            return

        backup_path = Path(args[0])
        if not backup_path.exists():
            print_error(f"Backup not found: {backup_path}")
            return

        print_header("Restoring Full System Backup")
        print_warning("This will overwrite all existing data! Continue? (y/N)")

        if input().lower() != 'y':
            print_info("Restore cancelled")
            return

        print_info(f"Restoring from: {backup_path}")

        # Restore database
        db_file = backup_path / "database.sql"
        if db_file.exists():
            print_info("1/3 Restoring database...")
            self.restore_database([str(db_file)])
        else:
            print_warning("Database backup not found, skipping")

        # Restore Redis
        redis_file = backup_path / "redis.rdb"
        if redis_file.exists():
            print_info("2/3 Restoring Redis...")
            run_command(["docker", "cp", str(redis_file), "reflectai-redis:/data/dump.rdb"], check=False)
            run_command(["docker", "restart", "reflectai-redis"], check=False)
        else:
            print_warning("Redis backup not found, skipping")

        # Restore configs
        configs_dir = backup_path / "configs"
        if configs_dir.exists():
            print_info("3/3 Restoring configurations...")
            import shutil
            if (configs_dir / ".env").exists():
                shutil.copy(configs_dir / ".env", ".env")
                print_success("✓ .env restored")
        else:
            print_warning("Config backup not found, skipping")

        print_success("\n✓ Full restore completed")

