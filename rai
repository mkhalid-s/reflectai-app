    def check_lint(self, args):
        """Run linting (use --fix to auto-fix issues)."""
        print_header("Running Linter")

        # Parse --fix flag from args list
        fix = '--fix' in args if isinstance(args, list) else getattr(args, 'fix', False)
        
        # Build ruff command
        ruff_args = ["check", "src/", "tests/"]
        if fix:
            ruff_args.append("--fix")

        # Try PDM environment first, then fallback to system
        if (self.project_root / ".venv" / "bin" / "ruff").exists():
            result = run_command(["pdm", "run", "ruff"] + ruff_args, check=False)
            if result.returncode != 0:
                if fix:
                    print_warning("Some linting issues remain after auto-fix")
                else:
                    print_error("Linting issues found! Run './rai check lint --fix' to auto-fix")
                sys.exit(1)
        elif check_command_exists("ruff"):
            result = run_command(["ruff"] + ruff_args, check=False)
            if result.returncode != 0:
                if fix:
                    print_warning("Some linting issues remain after auto-fix")
                else:
                    print_error("Linting issues found! Run './rai check lint --fix' to auto-fix")
                sys.exit(1)
        elif check_command_exists("flake8"):
            if fix:
                print_warning("flake8 doesn't support --fix. Install ruff for auto-fix: pdm add -d ruff")
            result = run_command(["flake8", "src/", "tests/"], check=False)
            if result.returncode != 0:
                print_error("Linting issues found!")
                sys.exit(1)
        else:
            print_warning("No linter found. Install with: pdm add -d ruff")
            return

