-- ReflectAI Complete Database Schema
-- Based on database-schema.md specifications
-- PostgreSQL 15+ with TimescaleDB extension

-- Enable required extensions
CREATE EXTENSION IF NOT EXISTS "uuid-ossp";
CREATE EXTENSION IF NOT EXISTS "timescaledb";
CREATE EXTENSION IF NOT EXISTS "btree_gin";

-- =====================================================
-- 1. CORE ENTITY TABLES
-- =====================================================

-- Users table with Slack integration
CREATE TABLE users (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    slack_user_id VARCHAR(50) UNIQUE NOT NULL,
    email VARCHAR(255) UNIQUE,
    display_name VARCHAR(100),
    real_name VARCHAR(100),
    team_id VARCHAR(50) NOT NULL,
    profile_data JSONB DEFAULT '{}',
    timezone VARCHAR(50) DEFAULT 'UTC',
    is_active BOOLEAN DEFAULT true,
    last_activity_at TIMESTAMPTZ,
    created_at TIMESTAMPTZ DEFAULT now(),
    updated_at TIMESTAMPTZ DEFAULT now(),
    
    -- Constraints
    CONSTRAINT users_slack_user_id_not_empty CHECK (LENGTH(slack_user_id) > 0),
    CONSTRAINT users_team_id_not_empty CHECK (LENGTH(team_id) > 0)
);

-- Indexes for users
CREATE INDEX idx_users_slack_user_id ON users(slack_user_id);
CREATE INDEX idx_users_team_id ON users(team_id);
CREATE INDEX idx_users_email ON users(email) WHERE email IS NOT NULL;
CREATE INDEX idx_users_active_last_activity ON users(is_active, last_activity_at);
CREATE INDEX idx_users_profile_data_gin ON users USING GIN (profile_data);

-- Activities table (TimescaleDB Hypertable)
CREATE TABLE activities (
    id UUID NOT NULL DEFAULT gen_random_uuid(),
    user_id UUID NOT NULL REFERENCES users(id) ON DELETE CASCADE,
    content TEXT NOT NULL,
    activity_type VARCHAR(50),
    source VARCHAR(50) DEFAULT 'slack',
    classification JSONB DEFAULT '{}',
    metrics JSONB DEFAULT '{}',
    processing_status VARCHAR(20) DEFAULT 'pending',
    confidence_score DECIMAL(3,2),
    evidence JSONB DEFAULT '{}',
    competency_areas TEXT[],
    workflow_id UUID,
    correlation_id VARCHAR(100),
    thread_ts VARCHAR(50),
    channel_id VARCHAR(50),
    timestamp TIMESTAMPTZ NOT NULL DEFAULT now(),
    created_at TIMESTAMPTZ DEFAULT now(),
    updated_at TIMESTAMPTZ DEFAULT now(),

    -- Constraints
    CONSTRAINT activities_content_not_empty CHECK (LENGTH(content) > 0),
    CONSTRAINT activities_processing_status_valid CHECK (
        processing_status IN ('pending', 'processing', 'complete', 'failed', 'archived')
    ),
    CONSTRAINT activities_confidence_valid CHECK (
        confidence_score IS NULL OR (confidence_score >= 0 AND confidence_score <= 1)
    ),
    -- Composite primary key for hypertable (must include partitioning column)
    PRIMARY KEY (id, timestamp)
);

-- Convert activities to hypertable (7-day chunks)
SELECT create_hypertable('activities', 'timestamp', chunk_time_interval => INTERVAL '7 days');

-- Indexes for activities
CREATE INDEX idx_activities_user_id_timestamp ON activities(user_id, timestamp DESC);
CREATE INDEX idx_activities_type_timestamp ON activities(activity_type, timestamp DESC);
CREATE INDEX idx_activities_status ON activities(processing_status);
CREATE INDEX idx_activities_workflow_id ON activities(workflow_id) WHERE workflow_id IS NOT NULL;
CREATE INDEX idx_activities_correlation_id ON activities(correlation_id) WHERE correlation_id IS NOT NULL;
CREATE INDEX idx_activities_thread_ts ON activities(thread_ts) WHERE thread_ts IS NOT NULL;
CREATE INDEX idx_activities_classification_gin ON activities USING GIN (classification);
CREATE INDEX idx_activities_metrics_gin ON activities USING GIN (metrics);
CREATE INDEX idx_activities_competency_areas_gin ON activities USING GIN (competency_areas);

-- Competencies table
CREATE TABLE competencies (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    user_id UUID NOT NULL REFERENCES users(id) ON DELETE CASCADE,
    competency_id VARCHAR(100) NOT NULL,
    competency_name VARCHAR(200) NOT NULL,
    current_level DECIMAL(3,2) NOT NULL,
    target_level DECIMAL(3,2),
    evidence_count INTEGER DEFAULT 0,
    last_evidence_date TIMESTAMPTZ,
    confidence_interval DECIMAL(3,2)[2], -- [lower, upper] bounds
    trend_direction VARCHAR(20) DEFAULT 'stable',
    trend_strength DECIMAL(3,2) DEFAULT 0,
    last_calculated_at TIMESTAMPTZ DEFAULT now(),
    created_at TIMESTAMPTZ DEFAULT now(),
    updated_at TIMESTAMPTZ DEFAULT now(),
    
    -- Constraints
    CONSTRAINT competencies_current_level_valid CHECK (current_level >= 0 AND current_level <= 5),
    CONSTRAINT competencies_target_level_valid CHECK (
        target_level IS NULL OR (target_level >= 0 AND target_level <= 5)
    ),
    CONSTRAINT competencies_trend_direction_valid CHECK (
        trend_direction IN ('improving', 'stable', 'declining')
    ),
    CONSTRAINT competencies_user_competency_unique UNIQUE (user_id, competency_id)
);

-- Indexes for competencies
CREATE INDEX idx_competencies_user_id ON competencies(user_id);
CREATE INDEX idx_competencies_competency_id ON competencies(competency_id);
CREATE INDEX idx_competencies_current_level ON competencies(current_level);
CREATE INDEX idx_competencies_trend ON competencies(trend_direction, trend_strength);
CREATE INDEX idx_competencies_last_calculated ON competencies(last_calculated_at);

-- Workflows table
CREATE TABLE workflows (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    user_id UUID NOT NULL REFERENCES users(id) ON DELETE CASCADE,
    workflow_type VARCHAR(50) NOT NULL,
    workflow_status VARCHAR(20) DEFAULT 'pending',
    input_data JSONB DEFAULT '{}',
    output_data JSONB DEFAULT '{}',
    context_data JSONB DEFAULT '{}',
    stage VARCHAR(50) DEFAULT 'initial',
    error_count INTEGER DEFAULT 0,
    last_error JSONB,
    correlation_id VARCHAR(100),
    parent_workflow_id UUID,
    temporal_workflow_id VARCHAR(200),
    started_at TIMESTAMPTZ DEFAULT now(),
    completed_at TIMESTAMPTZ,
    created_at TIMESTAMPTZ DEFAULT now(),
    updated_at TIMESTAMPTZ DEFAULT now(),
    
    -- Constraints
    CONSTRAINT workflows_status_valid CHECK (
        workflow_status IN ('pending', 'running', 'completed', 'failed', 'cancelled', 'paused')
    ),
    CONSTRAINT workflows_type_not_empty CHECK (LENGTH(workflow_type) > 0)
);

-- Indexes for workflows
CREATE INDEX idx_workflows_user_id ON workflows(user_id);
CREATE INDEX idx_workflows_status ON workflows(workflow_status);
CREATE INDEX idx_workflows_type ON workflows(workflow_type);
CREATE INDEX idx_workflows_correlation_id ON workflows(correlation_id) WHERE correlation_id IS NOT NULL;
CREATE INDEX idx_workflows_temporal_id ON workflows(temporal_workflow_id) WHERE temporal_workflow_id IS NOT NULL;
CREATE INDEX idx_workflows_parent_id ON workflows(parent_workflow_id) WHERE parent_workflow_id IS NOT NULL;
CREATE INDEX idx_workflows_started_at ON workflows(started_at DESC);

-- Reports table
CREATE TABLE reports (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    user_id UUID NOT NULL REFERENCES users(id) ON DELETE CASCADE,
    report_type VARCHAR(50) NOT NULL,
    title VARCHAR(200) NOT NULL,
    format VARCHAR(20) DEFAULT 'slack',
    status VARCHAR(20) DEFAULT 'pending',
    parameters JSONB DEFAULT '{}',
    content JSONB DEFAULT '{}',
    file_path VARCHAR(500),
    file_size_bytes BIGINT,
    page_count INTEGER,
    delivery_method VARCHAR(50),
    delivery_status VARCHAR(20),
    delivery_metadata JSONB DEFAULT '{}',
    generated_at TIMESTAMPTZ,
    expires_at TIMESTAMPTZ,
    created_at TIMESTAMPTZ DEFAULT now(),
    updated_at TIMESTAMPTZ DEFAULT now(),
    
    -- Constraints
    CONSTRAINT reports_format_valid CHECK (format IN ('slack', 'pdf', 'json', 'csv')),
    CONSTRAINT reports_status_valid CHECK (
        status IN ('pending', 'generating', 'ready', 'delivered', 'failed', 'expired')
    ),
    CONSTRAINT reports_delivery_status_valid CHECK (
        delivery_status IS NULL OR delivery_status IN ('pending', 'sent', 'failed', 'acknowledged')
    )
);

-- Indexes for reports
CREATE INDEX idx_reports_user_id ON reports(user_id);
CREATE INDEX idx_reports_type ON reports(report_type);
CREATE INDEX idx_reports_status ON reports(status);
CREATE INDEX idx_reports_generated_at ON reports(generated_at DESC);
CREATE INDEX idx_reports_expires_at ON reports(expires_at) WHERE expires_at IS NOT NULL;

-- =====================================================
-- 2. TIME-SERIES TABLES (TimescaleDB Hypertables)
-- =====================================================

-- Competency history (hypertable for trend analysis)
CREATE TABLE competency_history (
    id UUID NOT NULL DEFAULT gen_random_uuid(),
    user_id UUID NOT NULL REFERENCES users(id) ON DELETE CASCADE,
    competency_id VARCHAR(100) NOT NULL,
    level_value DECIMAL(3,2) NOT NULL,
    evidence_count INTEGER DEFAULT 0,
    confidence_score DECIMAL(3,2),
    change_reason VARCHAR(100),
    activity_id UUID,
    timestamp TIMESTAMPTZ NOT NULL DEFAULT now(),

    -- Constraints
    CONSTRAINT competency_history_level_valid CHECK (level_value >= 0 AND level_value <= 5),
    CONSTRAINT competency_history_confidence_valid CHECK (
        confidence_score IS NULL OR (confidence_score >= 0 AND confidence_score <= 1)
    ),
    -- Composite primary key for hypertable (must include partitioning column)
    PRIMARY KEY (id, timestamp)
);

-- Convert to hypertable (1-day chunks for detailed analysis)
SELECT create_hypertable('competency_history', 'timestamp', chunk_time_interval => INTERVAL '1 day');

-- Indexes for competency_history
CREATE INDEX idx_competency_history_user_competency_time ON competency_history(user_id, competency_id, timestamp DESC);
CREATE INDEX idx_competency_history_activity_id ON competency_history(activity_id) WHERE activity_id IS NOT NULL;

-- Events table (hypertable for system events)
CREATE TABLE events (
    id UUID NOT NULL DEFAULT gen_random_uuid(),
    event_type VARCHAR(50) NOT NULL,
    event_source VARCHAR(50) NOT NULL,
    user_id UUID REFERENCES users(id) ON DELETE SET NULL,
    correlation_id VARCHAR(100),
    event_data JSONB DEFAULT '{}',
    metadata JSONB DEFAULT '{}',
    processing_status VARCHAR(20) DEFAULT 'pending',
    processed_at TIMESTAMPTZ,
    timestamp TIMESTAMPTZ NOT NULL DEFAULT now(),

    -- Constraints
    CONSTRAINT events_type_not_empty CHECK (LENGTH(event_type) > 0),
    CONSTRAINT events_source_not_empty CHECK (LENGTH(event_source) > 0),
    CONSTRAINT events_processing_status_valid CHECK (
        processing_status IN ('pending', 'processing', 'processed', 'failed', 'skipped')
    ),
    -- Composite primary key for hypertable (must include partitioning column)
    PRIMARY KEY (id, timestamp)
);

-- Convert to hypertable (6-hour chunks for high-frequency events)
SELECT create_hypertable('events', 'timestamp', chunk_time_interval => INTERVAL '6 hours');

-- Indexes for events
CREATE INDEX idx_events_type_timestamp ON events(event_type, timestamp DESC);
CREATE INDEX idx_events_user_id_timestamp ON events(user_id, timestamp DESC) WHERE user_id IS NOT NULL;
CREATE INDEX idx_events_correlation_id ON events(correlation_id) WHERE correlation_id IS NOT NULL;
CREATE INDEX idx_events_status ON events(processing_status);
CREATE INDEX idx_events_event_data_gin ON events USING GIN (event_data);

-- =====================================================
-- 3. CONFIGURATION AND SESSION TABLES
-- =====================================================

-- User preferences table
CREATE TABLE user_preferences (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    user_id UUID NOT NULL REFERENCES users(id) ON DELETE CASCADE,
    preference_category VARCHAR(50) NOT NULL,
    preference_key VARCHAR(100) NOT NULL,
    preference_value JSONB NOT NULL,
    is_active BOOLEAN DEFAULT true,
    created_at TIMESTAMPTZ DEFAULT now(),
    updated_at TIMESTAMPTZ DEFAULT now(),
    
    -- Constraints
    CONSTRAINT user_preferences_category_not_empty CHECK (LENGTH(preference_category) > 0),
    CONSTRAINT user_preferences_key_not_empty CHECK (LENGTH(preference_key) > 0),
    CONSTRAINT user_preferences_unique UNIQUE (user_id, preference_category, preference_key)
);

-- Indexes for user_preferences
CREATE INDEX idx_user_preferences_user_id ON user_preferences(user_id);
CREATE INDEX idx_user_preferences_category ON user_preferences(preference_category);
CREATE INDEX idx_user_preferences_active ON user_preferences(is_active) WHERE is_active = true;

-- User sessions table
CREATE TABLE user_sessions (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    user_id UUID NOT NULL REFERENCES users(id) ON DELETE CASCADE,
    session_id VARCHAR(100) UNIQUE NOT NULL,
    session_type VARCHAR(50) DEFAULT 'slack_conversation',
    session_data JSONB DEFAULT '{}',
    context_data JSONB DEFAULT '{}',
    is_active BOOLEAN DEFAULT true,
    last_activity_at TIMESTAMPTZ DEFAULT now(),
    expires_at TIMESTAMPTZ,
    created_at TIMESTAMPTZ DEFAULT now(),
    updated_at TIMESTAMPTZ DEFAULT now(),
    
    -- Constraints
    CONSTRAINT user_sessions_session_id_not_empty CHECK (LENGTH(session_id) > 0),
    CONSTRAINT user_sessions_expires_future CHECK (expires_at IS NULL OR expires_at > created_at)
);

-- Indexes for user_sessions
CREATE INDEX idx_user_sessions_user_id ON user_sessions(user_id);
CREATE INDEX idx_user_sessions_session_id ON user_sessions(session_id);
CREATE INDEX idx_user_sessions_active ON user_sessions(is_active, last_activity_at) WHERE is_active = true;
CREATE INDEX idx_user_sessions_expires_at ON user_sessions(expires_at) WHERE expires_at IS NOT NULL;

-- =====================================================
-- 4. AUDIT AND COMPLIANCE TABLES
-- =====================================================

-- Audit events table (separate from main events for compliance)
CREATE TABLE audit_events (
    id UUID NOT NULL DEFAULT gen_random_uuid(),
    event_type VARCHAR(50) NOT NULL,
    table_name VARCHAR(100),
    record_id UUID,
    user_id UUID,
    action VARCHAR(20) NOT NULL,
    old_values JSONB,
    new_values JSONB,
    change_context JSONB DEFAULT '{}',
    client_info JSONB DEFAULT '{}',
    timestamp TIMESTAMPTZ NOT NULL DEFAULT now(),

    -- Constraints
    CONSTRAINT audit_events_action_valid CHECK (action IN ('CREATE', 'UPDATE', 'DELETE', 'SELECT', 'LOGIN', 'LOGOUT')),
    -- Composite primary key for hypertable (must include partitioning column)
    PRIMARY KEY (id, timestamp)
);

-- Convert to hypertable (1-month chunks for long-term retention)
SELECT create_hypertable('audit_events', 'timestamp', chunk_time_interval => INTERVAL '1 month');

-- Indexes for audit_events
CREATE INDEX idx_audit_events_timestamp ON audit_events(timestamp DESC);
CREATE INDEX idx_audit_events_user_id ON audit_events(user_id) WHERE user_id IS NOT NULL;
CREATE INDEX idx_audit_events_table_record ON audit_events(table_name, record_id) WHERE table_name IS NOT NULL;
CREATE INDEX idx_audit_events_action ON audit_events(action);

