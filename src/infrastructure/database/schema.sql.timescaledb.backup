-- Performance and maintenance views
CREATE VIEW user_competency_summary AS
SELECT 
    u.id as user_id,
    u.slack_user_id,
    u.display_name,
    COUNT(DISTINCT c.competency_id) as competency_count,
    AVG(c.current_level) as avg_competency_level,
    MAX(c.last_calculated_at) as last_assessment,
    COUNT(a.id) as total_activities
FROM users u
LEFT JOIN competencies c ON u.id = c.user_id
LEFT JOIN activities a ON u.id = a.user_id AND a.timestamp > now() - INTERVAL '30 days'
WHERE u.is_active = true
GROUP BY u.id, u.slack_user_id, u.display_name;

-- Activity performance view
CREATE VIEW activity_processing_stats AS
SELECT 
    DATE_TRUNC('hour', timestamp) as hour,
    processing_status,
    COUNT(*) as count,
    AVG(EXTRACT(EPOCH FROM (updated_at - created_at))) as avg_processing_time_seconds
FROM activities
WHERE timestamp > now() - INTERVAL '7 days'
GROUP BY DATE_TRUNC('hour', timestamp), processing_status
ORDER BY hour DESC;

