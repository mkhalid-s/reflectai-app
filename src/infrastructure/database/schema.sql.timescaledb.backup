-- Set up retention policies
SELECT add_retention_policy('activities', INTERVAL '2 years');
SELECT add_retention_policy('competency_history', INTERVAL '7 years');
SELECT add_retention_policy('events', INTERVAL '90 days');
SELECT add_retention_policy('audit_events', INTERVAL '7 years');

-- Set up compression policies (compress data older than 7 days)
ALTER TABLE activities SET (
    timescaledb.compress,
    timescaledb.compress_segmentby = 'user_id, activity_type',
    timescaledb.compress_orderby = 'timestamp DESC'
);

ALTER TABLE competency_history SET (
    timescaledb.compress,
    timescaledb.compress_segmentby = 'user_id, competency_id',
    timescaledb.compress_orderby = 'timestamp DESC'
);

SELECT add_compression_policy('activities', INTERVAL '7 days');
SELECT add_compression_policy('competency_history', INTERVAL '30 days');

-- =====================================================
-- 6. FUNCTIONS AND TRIGGERS
-- =====================================================

-- Update timestamp trigger function
CREATE OR REPLACE FUNCTION update_updated_at_column()
RETURNS TRIGGER AS $$
BEGIN
    NEW.updated_at = now();
    RETURN NEW;
END;
$$ language 'plpgsql';

-- Apply update triggers to relevant tables
CREATE TRIGGER update_users_updated_at BEFORE UPDATE ON users 
    FOR EACH ROW EXECUTE FUNCTION update_updated_at_column();
CREATE TRIGGER update_activities_updated_at BEFORE UPDATE ON activities 
    FOR EACH ROW EXECUTE FUNCTION update_updated_at_column();
CREATE TRIGGER update_competencies_updated_at BEFORE UPDATE ON competencies 
    FOR EACH ROW EXECUTE FUNCTION update_updated_at_column();
CREATE TRIGGER update_workflows_updated_at BEFORE UPDATE ON workflows 
    FOR EACH ROW EXECUTE FUNCTION update_updated_at_column();
CREATE TRIGGER update_reports_updated_at BEFORE UPDATE ON reports 
    FOR EACH ROW EXECUTE FUNCTION update_updated_at_column();
CREATE TRIGGER update_user_preferences_updated_at BEFORE UPDATE ON user_preferences 
    FOR EACH ROW EXECUTE FUNCTION update_updated_at_column();
CREATE TRIGGER update_user_sessions_updated_at BEFORE UPDATE ON user_sessions 
    FOR EACH ROW EXECUTE FUNCTION update_updated_at_column();

-- Function to calculate competency score with confidence interval
CREATE OR REPLACE FUNCTION calculate_competency_score(
    p_user_id UUID,
    p_competency_id VARCHAR(100)
) RETURNS TABLE (
    score DECIMAL(3,2),
    confidence DECIMAL(3,2),
    evidence_count INTEGER,
    trend VARCHAR(20)
) AS $$
DECLARE
    activity_count INTEGER;
    weighted_sum DECIMAL(5,2) := 0;
    total_weight DECIMAL(5,2) := 0;
    recency_weight DECIMAL(3,2);
    complexity_weight DECIMAL(3,2);
    final_score DECIMAL(3,2);
    confidence_score DECIMAL(3,2);
    trend_direction VARCHAR(20) := 'stable';
BEGIN
    -- Get recent activities for this competency
    SELECT COUNT(*) INTO activity_count
    FROM activities a
    WHERE a.user_id = p_user_id 
    AND p_competency_id = ANY(a.competency_areas)
    AND a.timestamp > now() - INTERVAL '90 days';
    
    IF activity_count = 0 THEN
        RETURN QUERY SELECT 0::DECIMAL(3,2), 0::DECIMAL(3,2), 0, 'stable'::VARCHAR(20);
        RETURN;
    END IF;
    
    -- Calculate weighted score based on recency and complexity
    FOR recency_weight, complexity_weight IN
        SELECT 
            GREATEST(0.1, 1.0 - EXTRACT(days FROM (now() - a.timestamp)) / 90.0) as recency,
            COALESCE(a.confidence_score, 0.5) as complexity
        FROM activities a
        WHERE a.user_id = p_user_id 
        AND p_competency_id = ANY(a.competency_areas)
        AND a.timestamp > now() - INTERVAL '90 days'
    LOOP
        weighted_sum := weighted_sum + (recency_weight * complexity_weight);
        total_weight := total_weight + recency_weight;
    END LOOP;
    
    -- Calculate final score (normalized to 0-5 scale)
    final_score := LEAST(5.0, (weighted_sum / total_weight) * 5.0);
    
    -- Calculate confidence based on evidence count
    confidence_score := LEAST(1.0, activity_count / 10.0);
    
    -- Determine trend (simplified)
    trend_direction := 'stable'; -- Would implement trend calculation based on recent changes
    
    RETURN QUERY SELECT final_score, confidence_score, activity_count, trend_direction;
END;
$$ LANGUAGE plpgsql;

-- Function to get user activity summary
CREATE OR REPLACE FUNCTION get_user_activity_summary(
    p_user_id UUID,
    p_days INTEGER DEFAULT 30
) RETURNS TABLE (
    total_activities INTEGER,
    unique_competencies INTEGER,
    avg_confidence DECIMAL(3,2),
    top_activity_type VARCHAR(50),
    activity_trend VARCHAR(20)
) AS $$
BEGIN
    RETURN QUERY
    WITH activity_stats AS (
        SELECT 
            COUNT(*) as total,
            COUNT(DISTINCT unnest(competency_areas)) as competencies,
            AVG(confidence_score) as confidence,
            MODE() WITHIN GROUP (ORDER BY activity_type) as top_type
        FROM activities
        WHERE user_id = p_user_id 
        AND timestamp > now() - (p_days || ' days')::INTERVAL
    )
    SELECT 
        COALESCE(total, 0)::INTEGER,
        COALESCE(competencies, 0)::INTEGER,
        COALESCE(confidence, 0)::DECIMAL(3,2),
        COALESCE(top_type, 'none')::VARCHAR(50),
        'stable'::VARCHAR(20) -- Simplified trend
    FROM activity_stats;
END;
$$ LANGUAGE plpgsql;

-- =====================================================
-- 6. LLM COST TRACKING (TimescaleDB Hypertable)
-- =====================================================

-- LLM Cost Records table for tracking AI usage and costs
CREATE TABLE cost_records (
    id BIGSERIAL NOT NULL,
    record_id UUID NOT NULL DEFAULT gen_random_uuid(),
    timestamp TIMESTAMPTZ NOT NULL DEFAULT NOW(),
    user_id TEXT NOT NULL,
    model_name TEXT NOT NULL,
    provider_name TEXT NOT NULL,
    model_tier TEXT NOT NULL,

    -- Token usage breakdown
    prompt_tokens INTEGER NOT NULL DEFAULT 0,
    completion_tokens INTEGER NOT NULL DEFAULT 0,
    total_tokens INTEGER NOT NULL DEFAULT 0,

    -- Cost tracking
    cost_usd DECIMAL(10,6) NOT NULL,

    -- Request metadata
    request_type TEXT DEFAULT 'general',
    department TEXT,
    correlation_id TEXT,
    request_duration_ms INTEGER,

    -- Timestamps
    created_at TIMESTAMPTZ NOT NULL DEFAULT NOW(),

    -- Constraints
    CONSTRAINT cost_records_tokens_positive CHECK (
        prompt_tokens >= 0 AND completion_tokens >= 0 AND total_tokens >= 0
    ),
    CONSTRAINT cost_records_cost_positive CHECK (cost_usd >= 0),
    CONSTRAINT cost_records_user_id_not_empty CHECK (LENGTH(user_id) > 0),
    CONSTRAINT cost_records_model_name_not_empty CHECK (LENGTH(model_name) > 0),

    -- Composite primary key for hypertable (must include partitioning column)
    PRIMARY KEY (id, timestamp)
);

-- Convert cost_records to hypertable (1-day chunks for cost data)
SELECT create_hypertable('cost_records', 'timestamp', chunk_time_interval => INTERVAL '1 day');

-- Indexes for cost_records
CREATE INDEX idx_cost_records_user_id_timestamp ON cost_records(user_id, timestamp DESC);
CREATE INDEX idx_cost_records_model_name_timestamp ON cost_records(model_name, timestamp DESC);
CREATE INDEX idx_cost_records_provider_timestamp ON cost_records(provider_name, timestamp DESC);
CREATE INDEX idx_cost_records_department_timestamp ON cost_records(department, timestamp DESC) WHERE department IS NOT NULL;
CREATE INDEX idx_cost_records_correlation_id ON cost_records(correlation_id) WHERE correlation_id IS NOT NULL;
CREATE INDEX idx_cost_records_request_type ON cost_records(request_type, timestamp DESC);

-- Continuous aggregate for daily cost rollups
CREATE MATERIALIZED VIEW cost_records_daily
WITH (timescaledb.continuous) AS
SELECT
    time_bucket('1 day', timestamp) AS day,
    user_id,
    model_name,
    provider_name,
    model_tier,
    department,
    request_type,
    COUNT(*) as request_count,
    SUM(prompt_tokens) as total_prompt_tokens,
    SUM(completion_tokens) as total_completion_tokens,
    SUM(total_tokens) as total_tokens_used,
    SUM(cost_usd) as total_cost_usd,
    AVG(cost_usd) as avg_cost_per_request,
    AVG(request_duration_ms) as avg_duration_ms
FROM cost_records
GROUP BY day, user_id, model_name, provider_name, model_tier, department, request_type;

-- Add refresh policy (refresh every hour, lag 1 hour)
SELECT add_continuous_aggregate_policy('cost_records_daily',
    start_offset => INTERVAL '3 days',
    end_offset => INTERVAL '1 hour',
    schedule_interval => INTERVAL '1 hour');

-- Continuous aggregate for hourly cost rollups (for real-time monitoring)
CREATE MATERIALIZED VIEW cost_records_hourly
WITH (timescaledb.continuous) AS
SELECT
    time_bucket('1 hour', timestamp) AS hour,
    user_id,
    model_name,
    provider_name,
    COUNT(*) as request_count,
    SUM(total_tokens) as total_tokens_used,
    SUM(cost_usd) as total_cost_usd,
    AVG(request_duration_ms) as avg_duration_ms
FROM cost_records
GROUP BY hour, user_id, model_name, provider_name;

-- Add refresh policy for hourly aggregate (refresh every 15 minutes)
SELECT add_continuous_aggregate_policy('cost_records_hourly',
    start_offset => INTERVAL '1 day',
    end_offset => INTERVAL '15 minutes',
    schedule_interval => INTERVAL '15 minutes');

-- Continuous aggregate for monthly cost summaries
CREATE MATERIALIZED VIEW cost_records_monthly
WITH (timescaledb.continuous) AS
SELECT
    time_bucket('1 month', timestamp) AS month,
    user_id,
    department,
    provider_name,
    SUM(cost_usd) as total_cost_usd,
    COUNT(*) as request_count,
    SUM(total_tokens) as total_tokens_used,
    AVG(cost_usd) as avg_cost_per_request
FROM cost_records
GROUP BY month, user_id, department, provider_name;

-- Cost analytics views
CREATE VIEW user_cost_summary AS
SELECT
    user_id,
    COUNT(*) as total_requests,
    SUM(cost_usd) as total_cost_usd,
    AVG(cost_usd) as avg_cost_per_request,
    SUM(total_tokens) as total_tokens_used,
    COUNT(DISTINCT model_name) as models_used,
    MAX(timestamp) as last_request_at,
    DATE_TRUNC('day', MAX(timestamp)) as last_request_date
FROM cost_records
WHERE timestamp > NOW() - INTERVAL '30 days'
GROUP BY user_id;

CREATE VIEW model_performance_summary AS
SELECT
    model_name,
    provider_name,
    model_tier,
    COUNT(*) as total_requests,
    SUM(cost_usd) as total_cost_usd,
    AVG(cost_usd) as avg_cost_per_request,
    AVG(total_tokens) as avg_tokens_per_request,
    AVG(request_duration_ms) as avg_duration_ms,
    SUM(total_tokens) / NULLIF(SUM(cost_usd), 0) as tokens_per_dollar
FROM cost_records
WHERE timestamp > NOW() - INTERVAL '7 days'
GROUP BY model_name, provider_name, model_tier
ORDER BY total_cost_usd DESC;

